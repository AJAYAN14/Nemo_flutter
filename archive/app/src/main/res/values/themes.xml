<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 
        Edge-to-Edge 主题配置
        参考: https://developer.android.com/develop/ui/views/layout/edge-to-edge
    -->
    <style name="Theme.Nemo" parent="Theme.Nemo.Splash">
        <item name="postSplashScreenTheme">@style/Theme.Nemo.App</item>
    </style>

    <style name="Theme.Nemo.App" parent="android:Theme.Material.Light.NoActionBar">
        <!-- 启用 Edge-to-Edge 模式 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>

    <style name="Theme.Nemo.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/nemo_primary_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>